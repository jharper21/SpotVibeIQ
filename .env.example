# Spotify authentication
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here

# AI intelligence
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
SYNC_SAMPLE_LIMIT=1000

# Source sampled by the weekly intelligence sync.
# Use a Spotify playlist ID/URL, or use "liked" for the current user's Liked Songs.
ARCHIVE_PLAYLIST_ID=your_archive_playlist_id_here

# Target playlists updated by the daily shuffle
MASTER_SHUFFLE_ID=your_master_shuffle_playlist_id_here
VIBE_1_ID=your_vibe_playlist_id_1
VIBE_2_ID=your_vibe_playlist_id_2
VIBE_3_ID=your_vibe_playlist_id_3
VIBE_4_ID=your_vibe_playlist_id_4
VIBE_5_ID=your_vibe_playlist_id_5
